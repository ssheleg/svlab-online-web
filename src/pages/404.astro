---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GradientMesh from "@/components/GradientMesh.astro";
import GridBg from "@/components/GridBg.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title={`404 — ${site.name}`}
  description="The page you were looking for does not exist."
>
  <section class="nf">
    <GradientMesh variant="hero" />
    <GridBg fade="both" />
    <div class="container-page inner">
      <span class="mono-label">// ERROR · 0x0404</span>
      <h1>Signal lost.</h1>
      <p>
        The page you were looking for does not exist or has been moved. The
        lab is still up — try the front door.
      </p>
      <div class="actions">
        <a class="btn-primary" href="/">Return home →</a>
        <a class="btn-secondary" href={`mailto:${site.email}`}>
          Report it
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    position: relative;
    overflow: hidden;
    min-height: 80vh;
    display: grid;
    place-items: center;
    padding-block: 4rem;
  }

  .inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 56ch;
  }

  h1 {
    margin-top: 1rem;
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: #fff;
  }

  p {
    margin-top: 1.25rem;
    color: var(--color-fg-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .actions {
    margin-top: 2rem;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
