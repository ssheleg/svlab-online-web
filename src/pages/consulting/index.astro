---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import GradientMesh from "@/components/GradientMesh.astro";
import GridBg from "@/components/GridBg.astro";
import ConsultingHubCard from "@/components/ConsultingHubCard.astro";
import { site } from "@/data/site";
import { consultingServices } from "@/data/consulting";
import { projects } from "@/data/projects";

const advisory = consultingServices["ai-advisory"];
const transformation = consultingServices["ai-transformation"];

const title = `Consulting · ${site.name}`;
const description = `AI advisory and AI transformation engagements with Siarhei Sheleh — solo AI operator from Warsaw. Apply AI where it moves the business, in weeks, not quarters.`;

const hubMailto = `mailto:${site.email}?subject=${encodeURIComponent("Consulting · SV Lab")}&body=${encodeURIComponent(
  [
    "Hi Siarhei,",
    "",
    "I'd like to discuss a consulting engagement.",
    "",
    "Company:",
    "Role:",
    "What we're trying to solve:",
    "Rough timeline:",
    "",
    "— ",
  ].join("\n"),
)}`;
const ctaAria = `Book a consultation — opens email to ${site.email}`;

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: `${site.name} — Consulting`,
  description,
  url: new URL("/consulting", site.url).toString(),
  provider: {
    "@type": "Organization",
    name: site.name,
    url: site.url,
  },
  areaServed: "Worldwide",
  serviceType: ["AI advisory", "AI transformation"],
  email: site.email,
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Consulting services",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: advisory.title,
          url: new URL("/consulting/ai-advisory", site.url).toString(),
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: transformation.title,
          url: new URL("/consulting/ai-transformation", site.url).toString(),
        },
      },
    ],
  },
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/og-consulting.png"
  extraSchemas={[offerSchema]}
>
  <Nav />
  <main id="main">
    <section class="hub-hero">
      <GradientMesh variant="hero" />
      <GridBg fade="bottom" />

      <div class="container-page hero-inner">
        <span class="kicker mono-label">
          <span class="dot"></span>
          // CONSULTING · SV LAB
        </span>

        <h1 class="hero-title reveal">
          Outside operator on your<br />
          <span class="gradient-text">AI roadmap.</span>
        </h1>

        <p class="hero-sub reveal">
          Two ways to work together. <strong>Advisory</strong> for teams that
          need to apply AI to a specific use case fast. <strong>Transformation</strong>
          for operators rewiring entire processes and orgs around AI. Both
          deliver working systems — not slide decks.
        </p>

        <div class="hero-actions reveal">
          <a class="btn-primary" href={hubMailto} aria-label={ctaAria}>
            Book a consultation
            <span aria-hidden="true">→</span>
            <span class="sr-only">contact@svlab.online</span>
          </a>
          <a class="btn-secondary" href="#services">See services ↓</a>
        </div>
      </div>
    </section>

    <section class="hub-services" id="services">
      <div class="container-page">
        <header class="head reveal">
          <span class="mono-label">// SERVICES</span>
          <h2>Pick the depth that matches the problem.</h2>
        </header>

        <div class="cards reveal">
          <ConsultingHubCard
            service={advisory}
            href="/consulting/ai-advisory"
            accent="cyan"
          />
          <ConsultingHubCard
            service={transformation}
            href="/consulting/ai-transformation"
            accent="violet"
          />
        </div>
      </div>
    </section>

    <section class="hub-why reveal">
      <div class="container-page">
        <header class="head">
          <span class="mono-label">// WHY ME</span>
          <h2>I ship AI products for a living.</h2>
          <p>
            Most consultants advise from PowerPoint. I advise from the same
            code I deploy on Monday morning.
          </p>
        </header>

        <div class="why-line" role="list" aria-label="Operator metrics">
          <span class="why-pill" role="listitem">
            <span class="why-pill-num">3</span>
            <span class="why-pill-label mono-label">live AI products</span>
          </span>
          <span class="why-pill" role="listitem">
            <span class="why-pill-num">11+</span>
            <span class="why-pill-label mono-label">prior shipped</span>
          </span>
          <span class="why-pill" role="listitem">
            <span class="why-pill-num">12+</span>
            <span class="why-pill-label mono-label">years</span>
          </span>
          <span class="why-pill" role="listitem">
            <span class="why-pill-num">1</span>
            <span class="why-pill-label mono-label">operator</span>
          </span>
        </div>

        <div class="why-products" aria-label="Live SV Lab products">
          <span class="mono-label why-products-label">// LIVE TODAY</span>
          <div class="why-products-row">
            {projects.map((p) => (
              <a
                class={`why-chip accent-${p.accent}`}
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="why-chip-mark" aria-hidden="true">
                  {p.name.charAt(0)}
                </span>
                <span class="why-chip-name">{p.name}</span>
                <span class="why-chip-domain mono-label">{p.domain}</span>
                <span class="why-chip-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="hub-cta">
      <GradientMesh variant="section" />
      <div class="container-page cta-inner reveal">
        <span class="mono-label">// LET'S TALK</span>
        <h2>
          Not sure which one fits?<br />
          <span class="gradient-text">Just send a sketch.</span>
        </h2>
        <p>
          Drop a paragraph about what you're trying to do — I'll reply within
          one business day with a recommended path (advisory, transformation,
          or "you don't need either yet").
        </p>
        <div class="actions">
          <a class="btn-primary" href={hubMailto} aria-label={ctaAria}>
            Book a consultation
            <span aria-hidden="true">→</span>
            <span class="sr-only">contact@svlab.online</span>
          </a>
          <a
            class="btn-secondary"
            href={`mailto:${site.email}`}
            aria-label={`Email ${site.email}`}
          >
            {site.email}
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .hub-hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(4rem, 9vw, 7rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.02);
    color: #c9d2e0;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.18);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .hero-title {
    margin-top: 1.4rem;
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: #fff;
    max-width: 18ch;
  }

  .hero-sub {
    margin-top: 1.4rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    max-width: 60ch;
  }

  .hero-sub strong {
    color: #fff;
    font-weight: 500;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hub-services {
    padding-block: clamp(4rem, 8vw, 7rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .head {
    max-width: 60ch;
  }

  .head h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #fff;
  }

  .head p {
    margin-top: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .cards {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .hub-why {
    padding-block: clamp(4rem, 8vw, 6.5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .why-line {
    margin-top: 2.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem 1.6rem;
    padding: 1.2rem 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 1.1rem;
    background:
      radial-gradient(circle at top right, rgba(34, 211, 238, 0.08), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0.005));
  }

  .why-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    padding-right: 1.4rem;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    flex: 0 0 auto;
  }

  .why-pill:last-child {
    border-right: none;
    padding-right: 0;
  }

  .why-pill-num {
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    font-feature-settings: "tnum";
    background: linear-gradient(120deg, #ffffff 0%, #67e8f9 65%, #a3e635 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .why-pill-label {
    color: #c9d2e0;
    text-transform: none;
    letter-spacing: 0.04em;
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .why-products {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .why-products-label {
    color: var(--color-fg-subtle);
  }

  .why-products-row {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 800px) {
    .why-products-row {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .why-chip {
    --chip-accent: #22d3ee;
    --chip-glow: rgba(34, 211, 238, 0.18);
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    grid-template-areas:
      "mark name arrow"
      "mark domain arrow";
    column-gap: 0.85rem;
    row-gap: 0.1rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.85rem;
    background: rgba(255, 255, 255, 0.025);
    text-decoration: none;
    color: inherit;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      background 220ms ease,
      box-shadow 220ms ease;
  }

  .why-chip.accent-cyan { --chip-accent: #22d3ee; --chip-glow: rgba(34, 211, 238, 0.22); }
  .why-chip.accent-lime { --chip-accent: #a3e635; --chip-glow: rgba(163, 230, 53, 0.20); }
  .why-chip.accent-violet { --chip-accent: #a78bfa; --chip-glow: rgba(167, 139, 250, 0.22); }

  .why-chip:hover {
    border-color: color-mix(in oklab, var(--chip-accent) 50%, transparent);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
    box-shadow: 0 18px 40px -28px var(--chip-glow);
  }

  .why-chip:hover .why-chip-arrow {
    transform: translate(2px, -2px);
    color: var(--chip-accent);
  }

  .why-chip-mark {
    grid-area: mark;
    width: 38px;
    height: 38px;
    border-radius: 0.55rem;
    display: grid;
    place-items: center;
    background:
      linear-gradient(
        135deg,
        color-mix(in oklab, var(--chip-accent) 18%, transparent),
        rgba(255, 255, 255, 0.02)
      );
    border: 1px solid color-mix(in oklab, var(--chip-accent) 30%, var(--color-border-strong));
    color: var(--chip-accent);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 1rem;
  }

  .why-chip-name {
    grid-area: name;
    color: #fff;
    font-weight: 500;
    letter-spacing: -0.01em;
    font-size: 0.98rem;
  }

  .why-chip-domain {
    grid-area: domain;
    color: var(--color-fg-subtle);
    font-size: 0.7rem;
  }

  .why-chip-arrow {
    grid-area: arrow;
    font-family: var(--font-mono);
    color: var(--color-fg-subtle);
    transition: transform 220ms ease, color 220ms ease;
  }

  .hub-cta {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }

  .hub-cta h2 {
    margin-top: 0.85rem;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: #fff;
  }

  .hub-cta p {
    margin-top: 1.25rem;
    margin-inline: auto;
    max-width: 56ch;
    color: var(--color-fg-muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .actions {
    margin-top: 2rem;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
