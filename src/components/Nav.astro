---
import Logo from "./Logo.astro";
import { site } from "@/data/site";

const path = Astro.url.pathname;
const norm = (p: string) => (p.length > 1 && p.endsWith("/") ? p.slice(0, -1) : p);
const here = norm(path);

type Link = { label: string; href: string; match: (p: string) => boolean };

// In-page anchor links (#products, #track-record, #contact) never get the
// active underline — otherwise multiple links would all light up at once on
// the home page and look "stuck". Only true page-level routes (Consulting,
// About) get the active state.
const links: Link[] = [
  {
    label: "Products",
    href: "/#products",
    match: () => false,
  },
  {
    label: "Track record",
    href: "/#track-record",
    match: () => false,
  },
  {
    label: "Consulting",
    href: "/consulting",
    match: (p) => p === "/consulting" || p.startsWith("/consulting/"),
  },
  {
    label: "About",
    href: "/about",
    match: (p) => p === "/about",
  },
  {
    label: "Contact",
    href: "/#contact",
    match: () => false,
  },
];

const ctaAria = `Email ${site.email}`;
---

<header class="nav-shell">
  <div class="container-page nav-row">
    <Logo />
    <nav class="links" aria-label="Primary">
      {links.map((l) => {
        const isActive = l.match(here);
        return (
          <a
            href={l.href}
            class:list={["nav-link", { "is-active": isActive }]}
            aria-current={isActive ? "page" : undefined}
          >
            {l.label}
          </a>
        );
      })}
    </nav>
    <a class="cta" href={`mailto:${site.email}`} aria-label={ctaAria}>
      <span class="cta-mono">contact@svlab.online</span>
      <span class="cta-mono cta-mono-mobile" aria-hidden="true">EMAIL</span>
      <span class="cta-arrow" aria-hidden="true">→</span>
    </a>
  </div>
</header>

<style>
  .nav-shell {
    position: sticky;
    top: 0;
    z-index: 40;
    backdrop-filter: blur(12px);
    background: linear-gradient(
      to bottom,
      rgba(7, 10, 18, 0.78),
      rgba(7, 10, 18, 0.5)
    );
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-block: 0.85rem;
  }

  .links {
    display: none;
    margin-left: auto;
    gap: 1.4rem;
    white-space: nowrap;
  }

  .nav-link {
    color: var(--color-fg-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 200ms ease;
    position: relative;
    padding-block: 0.25rem;
    -webkit-tap-highlight-color: transparent;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: linear-gradient(90deg, #22d3ee, #a3e635);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms ease;
    pointer-events: none;
  }

  /* Hover/focus underline only on devices that can actually hover. Touch
     devices keep :hover stuck after a tap, so we avoid the rule there. */
  @media (hover: hover) and (pointer: fine) {
    .nav-link:hover {
      color: #fff;
    }
    .nav-link:hover::after,
    .nav-link:focus-visible::after {
      transform: scaleX(1);
    }
  }

  .nav-link:focus-visible {
    color: #fff;
    outline: none;
  }

  .nav-link.is-active {
    color: #fff;
  }

  .nav-link.is-active::after {
    transform: scaleX(1);
  }

  .cta {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border-strong);
    background: rgba(255, 255, 255, 0.02);
    text-decoration: none;
    color: #fff;
    transition: border-color 200ms ease, background 200ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  @media (hover: hover) and (pointer: fine) {
    .cta:hover {
      border-color: rgba(34, 211, 238, 0.55);
      background: rgba(34, 211, 238, 0.06);
    }
  }

  .cta:focus-visible {
    outline: 2px solid rgba(103, 232, 249, 0.6);
    outline-offset: 2px;
  }

  .cta-mono {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .cta-mono-mobile {
    display: none;
    letter-spacing: 0.16em;
  }

  .cta-arrow {
    font-family: var(--font-mono);
    color: #67e8f9;
  }

  @media (min-width: 860px) {
    .links {
      display: inline-flex;
    }
    .cta {
      margin-left: 0;
    }
  }

  @media (max-width: 720px) {
    .cta-mono {
      display: none;
    }
    .cta-mono-mobile {
      display: inline;
    }
  }
</style>
