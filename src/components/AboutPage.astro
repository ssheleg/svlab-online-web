---
import { site } from "@/data/site";
import { trackRecord, formatTrackYears } from "@/data/track-record";
import GradientMesh from "./GradientMesh.astro";
import GridBg from "./GridBg.astro";

const selectedWork = trackRecord.slice(0, 6);

const stats = [
  { label: "// FOUNDED", value: `SV Lab · ${site.established}` },
  { label: "// HQ", value: site.location },
  { label: "// MODE", value: "Solo operator" },
  { label: "// SHIPPED", value: "11+ products · 12+ years" },
];

const disciplines = [
  {
    title: "Research & discovery",
    body: "Customer interviews, competitive teardowns, technical spikes. I validate before I build, then keep validating after.",
  },
  {
    title: "Full-stack engineering",
    body: "TypeScript end-to-end: agents, data pipelines, payments, infra. I write the code that ships, not just the spec.",
  },
  {
    title: "Go-to-market & growth",
    body: "Positioning, pricing, launch, distribution, first 1,000 users. GTM runs as the same loop as the build.",
  },
  {
    title: "Operations & org",
    body: "Stripe billing, support, legal, vendor stack, analytics — the boring infrastructure that keeps a one-person company compounding.",
  },
];

const aboutCtaSubject = encodeURIComponent("Hello SV Lab · about page");
const aboutCtaBody = encodeURIComponent(
  [
    "Hi Siarhei,",
    "",
    "I came in via the About page and I'd like to talk about ...",
    "",
    "— ",
  ].join("\n"),
);
---

<section class="about-hero">
  <GradientMesh variant="hero" />
  <GridBg fade="bottom" />

  <div class="container-page hero-grid">
    <div class="hero-copy">
      <span class="kicker mono-label">
        <span class="dot"></span>
        // ABOUT · SIARHEI SHELEH
      </span>

      <h1 class="hero-title reveal">
        Founder of <span class="gradient-text">SV Lab</span>.<br />
        Solo AI operator.
      </h1>

      <p class="hero-sub reveal">
        I'm <strong>Siarhei Sheleh</strong> — also known as Sergey Sheleg. I
        build, market, and operate AI products end-to-end from Warsaw, Poland.
        Twelve years of shipping behind me, three live products in front of me,
        and one inbox in the middle: <a href={`mailto:${site.email}`}>{site.email}</a>.
      </p>

      <div class="hero-actions reveal">
        <a class="btn-primary" href="/consulting">
          Book a consultation
          <span aria-hidden="true">→</span>
        </a>
        <a
          class="btn-secondary"
          href={`mailto:${site.email}?subject=${aboutCtaSubject}&body=${aboutCtaBody}`}
        >
          Email me
        </a>
      </div>

      <dl class="hero-stats reveal" aria-label="Profile">
        {stats.map((s) => (
          <div class="stat-cell">
            <dt class="mono-label">{s.label}</dt>
            <dd class="stat-val">{s.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <aside class="portrait-wrap reveal" aria-label="Portrait">
      <div class="portrait-frame glow-ring">
        <img
          src="/about/portrait.svg"
          alt={`${site.founder} — founder of SV Lab`}
          width="480"
          height="480"
          loading="eager"
          decoding="sync"
        />
      </div>
      <span class="portrait-caption mono-label">
        // {site.founder} · {site.alternateFounderName}
      </span>
    </aside>
  </div>
</section>

<section class="bio reveal">
  <div class="container-page bio-inner">
    <span class="mono-label">// BIO</span>
    <h2>Twelve years of shipping. One operator. Whole loop.</h2>

    <div class="bio-prose">
      <p>
        I started shipping internet products in 2013, working as a product
        developer for clients in tech, agro, AI, and hardware. From 2015 to
        2020 I led product and growth at <strong>Ultimate Guitar</strong>,
        helping musicians worldwide find chords, tabs, and lessons. From there
        I started co-founding and founding my own products: ESIMPlus,
        Nicegram, WhatPlantIsThis, Genie AI, HyperLancer, and Degenphone.
      </p>
      <p>
        In <strong>2024</strong> I formalized everything under SV Lab — a solo
        AI product lab. Today it runs three live products:
        <a href="https://prowl.chat" target="_blank" rel="noopener noreferrer">Prowl</a>
        (an AI marketing-intelligence agent),
        <a href="https://checkmydata.ai" target="_blank" rel="noopener noreferrer">CheckMyData</a>
        (an open-source NL-to-SQL agent), and
        <a href="https://privateclawd.com" target="_blank" rel="noopener noreferrer">PrivateClawd</a>
        (a managed cloud for AI agents).
      </p>
      <p>
        My edge is owning the full stack a product needs to exist:
        <strong>research</strong>, <strong>engineering</strong>,
        <strong>go-to-market</strong>, <strong>marketing</strong>, and
        <strong>operations</strong>. Most teams treat these as separate roles.
        As a solo operator, I treat them as one loop — and ship faster because
        of it. That same loop is what I bring to consulting and AI
        transformation engagements.
      </p>
    </div>
  </div>
</section>

<section class="disciplines reveal">
  <div class="container-page">
    <header class="head">
      <span class="mono-label">// HOW I OPERATE</span>
      <h2>Four disciplines, one loop.</h2>
    </header>

    <div class="grid">
      {disciplines.map((d) => (
        <article class="card tile">
          <h3>{d.title}</h3>
          <p>{d.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="selected reveal">
  <div class="container-page">
    <header class="head">
      <span class="mono-label">// SELECTED WORK</span>
      <h2>Things I've shipped.</h2>
      <p>
        A trimmed slice of the track record. Want the full list?
        <a href="/#track-record">See all 8 →</a>
      </p>
    </header>

    <ol class="rows" aria-label="Selected projects">
      {selectedWork.map((t, i) => (
        <li class="row">
          {t.url ? (
            <a
              class="row-inner is-link"
              href={t.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="idx mono-label">/{String(i + 1).padStart(2, "0")}</span>
              <span class="years mono-label">{formatTrackYears(t)}</span>
              <div class="body">
                <div class="title-line">
                  <span class="name">{t.name}</span>
                  {t.domain && <span class="dom mono-label">{t.domain}</span>}
                </div>
                <p class="blurb">{t.blurb}</p>
                <span class="role mono-label">{t.role}</span>
              </div>
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          ) : (
            <div class="row-inner is-static">
              <span class="idx mono-label">/{String(i + 1).padStart(2, "0")}</span>
              <span class="years mono-label">{formatTrackYears(t)}</span>
              <div class="body">
                <div class="title-line">
                  <span class="name">{t.name}</span>
                </div>
                <p class="blurb">{t.blurb}</p>
                <span class="role mono-label">{t.role}</span>
              </div>
            </div>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>

<section class="cta-band">
  <GradientMesh variant="section" />
  <div class="container-page cta-inner reveal">
    <span class="mono-label">// LET'S TALK</span>
    <h2>
      Need an outside operator on your<br />
      <span class="gradient-text">AI roadmap?</span>
    </h2>
    <p>
      Whether it's a tightly-scoped advisory sprint or a full AI transformation
      across your processes and org — I read every email and reply within one
      business day.
    </p>
    <div class="actions">
      <a class="btn-primary" href="/consulting">
        Book a consultation
        <span aria-hidden="true">→</span>
      </a>
      <a
        class="btn-secondary"
        href={`mailto:${site.email}?subject=${aboutCtaSubject}&body=${aboutCtaBody}`}
      >
        {site.email}
      </a>
    </div>
  </div>
</section>

<style>
  .about-hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(3rem, 7vw, 5.5rem);
    padding-bottom: clamp(4rem, 9vw, 7rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 3rem;
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 960px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: 4rem;
    }
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.02);
    color: #c9d2e0;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.18);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .hero-title {
    margin-top: 1.4rem;
    font-size: clamp(2.2rem, 5.6vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: #fff;
    max-width: 16ch;
  }

  .hero-sub {
    margin-top: 1.4rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
    font-size: clamp(1rem, 1.4vw, 1.1rem);
    max-width: 56ch;
  }

  .hero-sub strong {
    color: #fff;
    font-weight: 500;
  }

  .hero-sub a {
    color: #67e8f9;
    text-decoration: none;
    border-bottom: 1px solid rgba(103, 232, 249, 0.4);
    transition: border-color 200ms ease;
  }

  .hero-sub a:hover {
    border-bottom-color: #67e8f9;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-stats {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-block-end: 0;
  }

  @media (min-width: 720px) {
    .hero-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0;
  }

  .stat-val {
    font-size: 1rem;
    color: #fff;
    font-weight: 500;
    margin: 0;
  }

  .portrait-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: stretch;
    justify-self: stretch;
  }

  .portrait-frame {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: linear-gradient(
      135deg,
      rgba(34, 211, 238, 0.08),
      rgba(167, 139, 250, 0.06)
    );
    border: 1px solid var(--color-border);
  }

  .portrait-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portrait-caption {
    text-align: right;
    color: var(--color-fg-subtle);
  }

  /* Bio */
  .bio {
    padding-block: clamp(4rem, 8vw, 7rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .bio-inner {
    max-width: 880px;
  }

  .bio h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #fff;
    max-width: 22ch;
  }

  .bio-prose {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 64ch;
  }

  .bio-prose p {
    color: var(--color-fg-muted);
    line-height: 1.7;
    font-size: 1.02rem;
  }

  .bio-prose strong {
    color: #fff;
    font-weight: 500;
  }

  .bio-prose a {
    color: #67e8f9;
    text-decoration: none;
    border-bottom: 1px solid rgba(103, 232, 249, 0.4);
    transition: border-color 200ms ease;
  }

  .bio-prose a:hover {
    border-bottom-color: #67e8f9;
  }

  /* Disciplines */
  .disciplines {
    padding-block: clamp(4rem, 8vw, 6.5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .head {
    max-width: 60ch;
  }

  .head h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 3.6vw, 2.6rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #fff;
  }

  .head p {
    margin-top: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .head a {
    color: #67e8f9;
    text-decoration: none;
    border-bottom: 1px solid rgba(103, 232, 249, 0.4);
    margin-left: 0.4ch;
  }

  .grid {
    margin-top: 2.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .tile {
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .tile h3 {
    color: #fff;
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .tile p {
    color: var(--color-fg-muted);
    line-height: 1.55;
    font-size: 0.94rem;
  }

  /* Selected work */
  .selected {
    padding-block: clamp(4rem, 8vw, 6.5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rows {
    margin-top: 2.25rem;
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .row {
    border-bottom: 1px solid var(--color-border);
  }

  .row:last-child {
    border-bottom: none;
  }

  .row-inner {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: start;
    gap: 1.25rem;
    padding: 1.25rem 1rem;
    text-decoration: none;
    color: inherit;
    transition: background 200ms ease;
  }

  .row-inner.is-link:hover {
    background: linear-gradient(
      90deg,
      rgba(34, 211, 238, 0.04),
      rgba(163, 230, 53, 0.04)
    );
  }

  .row-inner.is-link:hover .arrow {
    transform: translate(2px, -2px);
    color: #67e8f9;
  }

  .row-inner.is-link:hover .name {
    color: #fff;
  }

  .idx {
    color: var(--color-fg-subtle);
    padding-top: 0.25rem;
    min-width: 2.5rem;
  }

  .years {
    color: var(--color-fg);
    padding-top: 0.25rem;
    min-width: 9rem;
    font-feature-settings: "tnum";
  }

  .body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .title-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }

  .name {
    color: #f3f6fb;
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    transition: color 200ms ease;
  }

  .dom {
    color: var(--color-fg-subtle);
  }

  .blurb {
    color: var(--color-fg-muted);
    line-height: 1.5;
    font-size: 0.94rem;
    margin: 0;
  }

  .role {
    color: var(--color-fg-subtle);
  }

  .arrow {
    font-family: var(--font-mono);
    color: var(--color-fg-subtle);
    padding-top: 0.2rem;
    transition: transform 220ms ease, color 220ms ease;
  }

  @media (max-width: 700px) {
    .row-inner {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        "idx arrow"
        "years arrow"
        "body body";
      gap: 0.4rem;
      padding: 1.1rem 0.5rem;
    }

    .idx {
      grid-area: idx;
    }
    .years {
      grid-area: years;
      min-width: 0;
    }
    .body {
      grid-area: body;
      margin-top: 0.4rem;
    }
    .arrow {
      grid-area: arrow;
      align-self: start;
    }
  }

  /* CTA */
  .cta-band {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    overflow: hidden;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }

  .cta-band h2 {
    margin-top: 0.85rem;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: #fff;
  }

  .cta-band p {
    margin-top: 1.25rem;
    margin-inline: auto;
    max-width: 56ch;
    color: var(--color-fg-muted);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .actions {
    margin-top: 2rem;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
