---
interface Props {
  variant?: "hero" | "section";
}
const { variant = "hero" } = Astro.props;
---

<div class:list={["mesh", variant]} aria-hidden="true">
  <span class="blob b1"></span>
  <span class="blob b2"></span>
  <span class="blob b3"></span>
</div>

<style>
  .mesh {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .blob {
    position: absolute;
    border-radius: 999px;
    filter: blur(90px);
    opacity: 0.55;
    will-change: transform;
    animation: drift 18s ease-in-out infinite;
  }

  .hero .b1 {
    width: 50vw;
    height: 50vw;
    max-width: 720px;
    max-height: 720px;
    left: -10%;
    top: -15%;
    background: radial-gradient(
      circle at center,
      rgba(34, 211, 238, 0.55),
      transparent 70%
    );
  }

  .hero .b2 {
    width: 45vw;
    height: 45vw;
    max-width: 640px;
    max-height: 640px;
    right: -10%;
    top: 10%;
    background: radial-gradient(
      circle at center,
      rgba(167, 139, 250, 0.5),
      transparent 70%
    );
    animation-delay: -6s;
  }

  .hero .b3 {
    width: 40vw;
    height: 40vw;
    max-width: 560px;
    max-height: 560px;
    left: 20%;
    bottom: -25%;
    background: radial-gradient(
      circle at center,
      rgba(163, 230, 53, 0.35),
      transparent 70%
    );
    animation-delay: -12s;
  }

  .section .blob {
    opacity: 0.3;
  }

  .section .b1 {
    width: 40vw;
    height: 40vw;
    max-width: 540px;
    max-height: 540px;
    left: -8%;
    top: 30%;
    background: radial-gradient(
      circle at center,
      rgba(34, 211, 238, 0.35),
      transparent 70%
    );
  }

  .section .b2 {
    width: 36vw;
    height: 36vw;
    max-width: 480px;
    max-height: 480px;
    right: -10%;
    bottom: 0;
    background: radial-gradient(
      circle at center,
      rgba(163, 230, 53, 0.25),
      transparent 70%
    );
    animation-delay: -8s;
  }

  .section .b3 {
    display: none;
  }

  @keyframes drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, -3%, 0) scale(1.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none;
    }
  }
</style>
