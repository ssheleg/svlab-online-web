---
import GradientMesh from "./GradientMesh.astro";
import ProjectCard from "./ProjectCard.astro";
import { projects } from "@/data/projects";
---

<section class="projects" id="products">
  <GradientMesh variant="section" />

  <div class="container-page inner">
    <header class="head reveal">
      <span class="mono-label">// LIVE PRODUCTS · SV LAB</span>
      <h2>Three products. Already shipping.</h2>
      <p>
        Every product below is live, paid, and operated end-to-end by me at
        SV Lab. From idea to revenue, in the open.
      </p>
    </header>

    <div class="grid">
      {projects.map((project, i) => (
        <div class="cell reveal">
          <ProjectCard project={project} index={i} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .inner {
    position: relative;
    z-index: 1;
  }

  .head {
    max-width: 60ch;
  }

  .head h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #fff;
  }

  .head p {
    margin-top: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .grid {
    margin-top: 2.75rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 760px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .cell {
    display: flex;
  }

  .cell > :global(*) {
    flex: 1;
  }
</style>
