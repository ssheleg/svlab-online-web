---
import GradientMesh from "./GradientMesh.astro";
import GridBg from "./GridBg.astro";
import { site } from "@/data/site";
---

<section class="hero" id="top">
  <GradientMesh variant="hero" />
  <GridBg fade="bottom" />

  <div class="container-page hero-inner">
    <span class="kicker mono-label">
      <span class="dot"></span>
      // SV LAB · WARSAW, PL · EST. {site.established}
    </span>

    <h1 class="hero-title reveal">
      A <span class="gradient-text">solo AI product lab</span><br />
      from Poland.
    </h1>

    <p class="hero-sub reveal">
      I design, build, and scale agentic, data-native, growth-ready AI
      products. Three live products today. Twelve years of shipping behind
      them.
    </p>

    <div class="hero-actions reveal">
      <a class="btn-primary" href="#products">
        See the lab
        <span aria-hidden="true">↓</span>
      </a>
      <a class="btn-secondary" href={`mailto:${site.email}`}>
        Get in touch
      </a>
    </div>

    <div class="hero-strip reveal" role="list">
      <div class="strip-cell" role="listitem">
        <span class="mono-label">// SHIPPED</span>
        <span class="strip-val">11+ products</span>
      </div>
      <div class="strip-cell" role="listitem">
        <span class="mono-label">// LIVE</span>
        <span class="strip-val">3 active SV Lab</span>
      </div>
      <div class="strip-cell" role="listitem">
        <span class="mono-label">// MODE</span>
        <span class="strip-val">Solo operator</span>
      </div>
      <div class="strip-cell" role="listitem">
        <span class="mono-label">// EXPERIENCE</span>
        <span class="strip-val">12+ years</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(4rem, 9vw, 7rem);
    padding-bottom: clamp(5rem, 12vw, 9rem);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.4rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.02);
    color: #c9d2e0;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #34d399;
    box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.18);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .hero-title {
    margin-top: 1.4rem;
    font-size: clamp(2.4rem, 6.4vw, 5.2rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: #fff;
    max-width: 18ch;
  }

  .hero-sub {
    margin-top: 1.4rem;
    max-width: 56ch;
    color: var(--color-fg-muted);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.5;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-strip {
    margin-top: 3.25rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 720px) {
    .hero-strip {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .strip-cell {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .strip-val {
    font-size: 1.1rem;
    color: #fff;
    font-weight: 500;
  }
</style>
