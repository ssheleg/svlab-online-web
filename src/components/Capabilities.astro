---
import { capabilities } from "@/data/capabilities";

const icons: Record<string, string> = {
  agent: "M4 6h7M4 12h12M4 18h9 M17 6l3 3-3 3",
  data: "M4 7c0-1.66 3.58-3 8-3s8 1.34 8 3v10c0 1.66-3.58 3-8 3s-8-1.34-8-3V7zM4 7c0 1.66 3.58 3 8 3s8-1.34 8-3M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3",
  intel: "M3 12l4-8 5 16 4-10 5 6",
  cloud: "M7 18a5 5 0 1 1 1.5-9.78A6 6 0 0 1 19 13a4 4 0 0 1-1 7H7z",
  shield: "M12 3l8 4v6c0 5-3.5 8-8 8s-8-3-8-8V7l8-4zm-3 9l2.5 2.5L16 9.5",
  growth: "M3 17l6-6 4 4 7-9 M14 6h6v6",
};
---

<section class="caps" id="capabilities">
  <div class="container-page inner">
    <header class="head reveal">
      <span class="mono-label">// WHAT I DO</span>
      <h2>What I actually do.</h2>
      <p>
        Six disciplines, one operator. The whole loop, owned by one person —
        which is exactly why it ships.
      </p>
    </header>

    <div class="grid">
      {capabilities.map((cap) => (
        <article class="card tile reveal">
          <div class="icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              width="22"
              height="22"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={icons[cap.icon]}></path>
            </svg>
          </div>
          <h3>{cap.title}</h3>
          <p>{cap.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .caps {
    position: relative;
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .inner {
    position: relative;
    z-index: 1;
  }

  .head {
    max-width: 60ch;
  }

  .head h2 {
    margin-top: 0.85rem;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: #fff;
  }

  .head p {
    margin-top: 1rem;
    color: var(--color-fg-muted);
    line-height: 1.6;
  }

  .grid {
    margin-top: 2.75rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tile {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .icon {
    width: 40px;
    height: 40px;
    border-radius: 0.6rem;
    background: linear-gradient(
      135deg,
      rgba(34, 211, 238, 0.16),
      rgba(167, 139, 250, 0.16)
    );
    color: #67e8f9;
    display: grid;
    place-items: center;
    border: 1px solid rgba(34, 211, 238, 0.25);
  }

  .tile h3 {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .tile p {
    color: var(--color-fg-muted);
    line-height: 1.55;
    font-size: 0.94rem;
  }
</style>
